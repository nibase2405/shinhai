{
  "name": "shinehai-travel",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "cf:build": "pnpm --filter shanghai-travel-cloudflare-site cf:types && pnpm --filter shanghai-travel-cloudflare-site typecheck",
    "cf:deploy": "pnpm --filter shanghai-travel-cloudflare-site deploy",
    "cf:dry-run": "pnpm --filter shanghai-travel-cloudflare-site dry-run"
  },
  "dependencies": {
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.39.1",
    "eslint-config-next": "latest",
    "tailwindcss": "latest",
    "typescript": "latest"
  }
}
